// /tmp/multisource_droir_ye/C.sol.C.test[routing]() -> void:
test:
    txna ApplicationArgs 1
    dup
    len
    intc_0 // 32
    ==
    assert // invalid number of bytes for arc4.uint256
    txna ApplicationArgs 2
    dup
    len
    intc_0 // 32
    ==
    assert // invalid number of bytes for arc4.uint256
    txn GroupIndex
    bz test_ternary_false@3
    txn GroupIndex
    intc_1 // 1
    -
    gtxns Amount

test_ternary_merge@4:
    !
    assert // not payable
    dig 1
    callsub g
    dup
    len
    intc_0 // 32
    <=
    assert // overflow
    intc_0 // 32
    bzero
    swap
    dig 1
    b|
    dig 2
    callsub f
    dup
    len
    intc_0 // 32
    <=
    assert // overflow
    uncover 2
    b|
    concat
    pushbytes 0x151f7c75
    swap
    concat
    log
    intc_1 // 1
    return

test_ternary_false@3:
