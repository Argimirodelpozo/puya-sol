main_after_if_else@2:
    pushbytes 0xef8d5f92 // method "test(uint256,uint256)(uint256,uint256)"
    txna ApplicationArgs 0
    match main_test_route@4
    err

main_test_route@4:
    txn OnCompletion
    !
    txn ApplicationID
    &&
    assert
    b test


// /tmp/multisource_droir_ye/C.sol.f(x: bytes) -> bytes:
f:
    proto 1 1
    frame_dig -1
